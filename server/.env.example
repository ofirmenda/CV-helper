# ─── COPY THIS TO server/.env (in the same folder) AND FILL IN ───
# server/.env is gitignored — never commit secrets.

# ─── AI provider ─────────────────────────────────────────────────
# 'mock' (default, no key needed) or 'openai'
AI_PROVIDER=mock

# Only required when AI_PROVIDER=openai. The whole team shares this one key.
OPENAI_API_KEY=
# Default: gpt-4o (best quality, ~$0.014 per tailoring call).
# Set OPENAI_MODEL=gpt-4o-mini for ~10x cheaper if you're testing a lot.
OPENAI_MODEL=gpt-4o

# ─── Auth ────────────────────────────────────────────────────────
# 'dev' (email-only sign-in, fine for local dev) or 'google' (real OAuth).
AUTH_PROVIDER=dev

# Required only when AUTH_PROVIDER=google. Get these from
# https://console.cloud.google.com → Credentials → OAuth client ID.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ─── Admin ───────────────────────────────────────────────────────
# The first user who signs in with this email is auto-flagged admin +
# auto-approved. They can then approve other users from Settings → Manage users.
ADMIN_EMAIL=

# ─── Server-side secrets ─────────────────────────────────────────
# Both ≥ 32 random chars. Generate with:
#   openssl rand -hex 32   (POSIX shells)
#   [System.Guid]::NewGuid().ToString('N') + [System.Guid]::NewGuid().ToString('N')   (PowerShell)
# Used to sign session cookies and to encrypt OpenAI keys saved in the DB.
SESSION_SECRET=
CRYPTO_SECRET=

# ─── Server ──────────────────────────────────────────────────────
PORT=4000
# HOST=0.0.0.0 binds on all interfaces (needed on Fly); leave unset in dev to bind to localhost only.
# DATA_DIR=/data         # SQLite + sessions live here; override to point at a mounted volume.
# UPLOAD_DIR=/tmp/uploads # Multer scratch dir; safe to point at tmpfs.

# ─── Dev-signin override (production only) ───────────────────────
# In NODE_ENV=production we BLOCK /api/auth/dev-signin by default so a public
# URL can't be used to spam-create pending accounts. If you really want dev
# sign-in enabled in production (you usually don't), set this to "true".
# ALLOW_DEV_SIGNIN_IN_PROD=true
